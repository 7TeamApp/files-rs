{
    "compilerOptions": {
        "target": "esnext",
        "lib": ["esnext", "DOM"],
        "module": "esnext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "paths": {
            "files-rs": ["."]
        },
        "resolveJsonModule": true,
        "typeRoots": ["**/types/**/*", "**/@types/**/*", "**/*.d.ts"],
        "allowJs": true,
        "strict": true,
        "strictNullChecks": true
    },
    "exclude": ["dist/index.*"]
}
